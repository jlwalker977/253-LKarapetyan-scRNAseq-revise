discriminating_markers <- c(
# gdT
"TRDC",   "TRDV1",  "TRDV2",  "GNLY",
# Early Activated / Memory
"CD69",   "FOS",    "CCR7",   "IL7R",
# ISG Macs
"ISG15",  "IFIT1",  "MX1",    "CD68"
)
FeaturePlot(
dat_tc4_clean,
features   = discriminating_markers,
ncol       = 4,
order      = TRUE,
min.cutoff = "q10",
cols       = c("lightgrey", "blueviolet")
)
DotPlot(
seurat_obj,
features  = discriminating_markers,
group.by  = "seurat_clusters"
) +
RotatedAxis() +
scale_color_gradient2(low = "steelblue", mid = "white", high = "firebrick") +
ggtitle("Marker comparison: gdT vs ISG Mac vs Early Activated/Memory")
