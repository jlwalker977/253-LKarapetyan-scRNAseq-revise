s <- NormalizeData(s)
s <- FindVariableFeatures(s)
s <- ScaleData(s)
s <- RunPCA(s)
s <- RunUMAP(s, dims = 1:20)
sweep.res   <- paramSweep(s, PCs = 1:20, sct = FALSE)
sweep.stats <- summarizeSweep(sweep.res, GT = FALSE)
pK_df <- sweep.stats %>%
group_by(pK) %>%
summarise(BCreal = mean(BCreal, na.rm = TRUE), .groups = "drop") %>%
arrange(desc(BCreal))
pK   <- as.numeric(as.character(pK_df$pK[1]))
nExp <- round(0.08 * ncol(s))
cat("Sample:", unique(s$Patient.Number), "| pK:", pK, "| nExp:", nExp, "\n")
s <- doubletFinder(
s,
PCs        = 1:20,
pN         = 0.25,
pK         = pK,
nExp       = nExp,
reuse.pANN = FALSE,
sct        = FALSE
)
DF_col <- grep("DF.classifications", colnames(s@meta.data), value = TRUE)
cat("Classification column:", DF_col, "\n")
print(table(s@meta.data[[DF_col]]))
s_clean <- subset(s, subset = !!sym(DF_col) == "Singlet")
cat("Cells before:", ncol(s), "| after:", ncol(s_clean),
"| removed:", ncol(s) - ncol(s_clean), "\n\n")
return(s_clean)
})
packageVersion("Seurat")
class(dat_tc4[["RNA"]])
sample_list <- SplitObject(dat_tc4, split.by = "Patient.Number")
sample_list <- lapply(sample_list, function(s) {
s <- NormalizeData(s)
s <- FindVariableFeatures(s)
s <- ScaleData(s)
s <- RunPCA(s)
s <- RunUMAP(s, dims = 1:20)
# ── Convert Assay5 → Assay AFTER scaling, BEFORE paramSweep ──────────────
DefaultAssay(s) <- "RNA"
s[["RNA"]]      <- as(object = s[["RNA"]], Class = "Assay")
sweep.res   <- paramSweep(s, PCs = 1:20, sct = FALSE)
sweep.stats <- summarizeSweep(sweep.res, GT = FALSE)
pK_df <- sweep.stats %>%
group_by(pK) %>%
summarise(BCreal = mean(BCreal, na.rm = TRUE), .groups = "drop") %>%
arrange(desc(BCreal))
pK   <- as.numeric(as.character(pK_df$pK[1]))
nExp <- round(0.08 * ncol(s))
cat("Sample:", unique(s$Patient.Number), "| pK:", pK, "| nExp:", nExp, "\n")
s <- doubletFinder(
s,
PCs        = 1:20,
pN         = 0.25,
pK         = pK,
nExp       = nExp,
reuse.pANN = FALSE,
sct        = FALSE
)
DF_col <- grep("DF.classifications", colnames(s@meta.data), value = TRUE)
cat("Classification column:", DF_col, "\n")
print(table(s@meta.data[[DF_col]]))
s_clean <- subset(s, subset = !!sym(DF_col) == "Singlet")
cat("Cells before:", ncol(s), "| after:", ncol(s_clean),
"| removed:", ncol(s) - ncol(s_clean), "\n\n")
return(s_clean)
})
# ── Isolate first sample and debug step by step ───────────────────────────
s <- SplitObject(dat_tc4, split.by = "Patient.Number")[[1]]
s <- NormalizeData(s)
s <- FindVariableFeatures(s)
s <- ScaleData(s)
s <- RunPCA(s)
s <- RunUMAP(s, dims = 1:20)
# ── Layer check before conversion ─────────────────────────────────────────
cat("Layers before conversion:\n")
print(Layers(s))
# ── Collapse layers ───────────────────────────────────────────────────────
s <- JoinLayers(s, assay = "RNA")
cat("Layers after JoinLayers:\n")
print(Layers(s))
# ── Convert ───────────────────────────────────────────────────────────────
s[["RNA"]] <- as(object = s[["RNA"]], Class = "Assay")
cat("Assay class after conversion:\n")
print(class(s[["RNA"]]))
# ── paramSweep ────────────────────────────────────────────────────────────
cat("Running paramSweep...\n")
sweep.res   <- paramSweep(s, PCs = 1:20, sct = FALSE)
sweep.stats <- summarizeSweep(sweep.res, GT = FALSE)
pK   <- 0.03    # use known pK to skip pK extraction
nExp <- round(0.08 * ncol(s))
# ── doubletFinder step ────────────────────────────────────────────────────
cat("Running doubletFinder...\n")
s <- doubletFinder(
s,
PCs        = 1:20,
pN         = 0.25,
pK         = pK,
nExp       = nExp,
reuse.pANN = FALSE,
sct        = FALSE
)
library(scDblFinder)
# ── Switch to scDblFinder — works natively with Seurat v5 ─────────────────
library(scDblFinder)
library(SingleCellExperiment)
sample_list <- SplitObject(dat_tc4, split.by = "Patient.Number")
sample_list <- lapply(sample_list, function(s) {
cat("Processing sample:", unique(s$Patient.Number), "\n")
# ── Convert to SingleCellExperiment ───────────────────────────────────────
sce <- as.SingleCellExperiment(s)
# ── Run scDblFinder ───────────────────────────────────────────────────────
sce <- scDblFinder(sce)
# ── Transfer results back to Seurat ───────────────────────────────────────
s$scDblFinder.class  <- sce$scDblFinder.class   # "singlet" or "doublet"
s$scDblFinder.score  <- sce$scDblFinder.score   # doublet probability 0-1
cat("Doublets found:", sum(sce$scDblFinder.class == "doublet"), "\n")
cat("Singlets kept:", sum(sce$scDblFinder.class == "singlet"), "\n\n")
# ── Remove doublets ───────────────────────────────────────────────────────
s_clean <- subset(s, subset = scDblFinder.class == "singlet")
cat("Cells before:", ncol(s), "| after:", ncol(s_clean),
"| removed:", ncol(s) - ncol(s_clean), "\n\n")
return(s_clean)
})
# ── Re-merge ──────────────────────────────────────────────────────────────
dat_tc4_clean <- merge(sample_list[[1]], y = sample_list[-1])
cat("Final merged cell count:", ncol(dat_tc4_clean), "\n")
# ── Visualize ─────────────────────────────────────────────────────────────
FeaturePlot(dat_tc4_clean, features = "scDblFinder.score") +
ggtitle("scDblFinder doublet score")
# ── Re-process merged object after doublet removal ────────────────────────
DefaultAssay(dat_tc4_clean) <- "RNA"
dat_tc4_clean <- NormalizeData(dat_tc4_clean)
dat_tc4_clean <- FindVariableFeatures(dat_tc4_clean)
dat_tc4_clean <- ScaleData(dat_tc4_clean)
dat_tc4_clean <- RunPCA(dat_tc4_clean)
dat_tc4_clean <- RunUMAP(dat_tc4_clean, dims = 1:20)
# ── Now visualize ─────────────────────────────────────────────────────────
FeaturePlot(dat_tc4_clean, features = "scDblFinder.score") +
ggtitle("scDblFinder doublet score")
DimPlot(dat_tc4_clean,
group.by = "scDblFinder.class",
cols     = c("singlet" = "grey80", "doublet" = "red")) +
ggtitle("scDblFinder doublet calls")
